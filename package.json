{
  "name": "open-db-nexus",
  "displayName": "Open DB Nexus",
  "description": "A VS Code multi-database client extension with schema explorer, query runner, and dependency graph tooling.",
  "version": "0.0.2",
  "publisher": "piupiutenshi",
  "license": "MIT",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openDbNexus",
          "title": "Open DB Nexus",
          "icon": "resources/db-nexus.svg"
        }
      ]
    },
    "views": {
      "openDbNexus": [
        {
          "id": "openDbNexus.connections",
          "name": "Connections"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "openDbNexus.connections",
        "contents": "No database connections yet.\n[Add Connection](command:openDbNexus.addConnection)"
      }
    ],
    "commands": [
      {
        "command": "openDbNexus.helloWorld",
        "title": "Open DB Nexus: Hello World"
      },
      {
        "command": "openDbNexus.addConnection",
        "title": "Open DB Nexus: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "openDbNexus.refreshConnections",
        "title": "Open DB Nexus: Refresh Connections",
        "icon": "$(refresh)"
      },
      {
        "command": "openDbNexus.removeConnection",
        "title": "Open DB Nexus: Remove Connection",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "openDbNexus.addConnection",
          "when": "view == openDbNexus.connections",
          "group": "navigation@1"
        },
        {
          "command": "openDbNexus.refreshConnections",
          "when": "view == openDbNexus.connections",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "openDbNexus.removeConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./ --noEmit",
    "bundle": "node esbuild.js",
    "bundle:watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "check": "npm run compile && npm run lint && npm test && npm run package"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.9"
  }
}
