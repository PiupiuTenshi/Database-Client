{
  "name": "open-db-nexus",
  "displayName": "Open DB Nexus",
  "description": "A VS Code multi-database client extension with schema explorer, query runner, and dependency graph tooling.",
  "version": "0.0.9",
  "publisher": "piupiutenshi",
  "license": "MIT",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openDbNexus",
          "title": "Open DB Nexus",
          "icon": "resources/db-nexus.svg"
        }
      ]
    },
    "views": {
      "openDbNexus": [
        {
          "id": "openDbNexus.connections",
          "name": "Connections"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "openDbNexus.connections",
        "contents": "No database connections yet.\n[Add Connection](command:openDbNexus.addConnection)"
      }
    ],
    "commands": [
      {
        "command": "openDbNexus.helloWorld",
        "title": "Open DB Nexus: Hello World"
      },
      {
        "command": "openDbNexus.addConnection",
        "title": "Open DB Nexus: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "openDbNexus.editConnection",
        "title": "Open DB Nexus: Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "openDbNexus.testConnection",
        "title": "Open DB Nexus: Test Connection",
        "icon": "$(plug)"
      },
      {
        "command": "openDbNexus.deleteConnection",
        "title": "Open DB Nexus: Delete Connection",
        "icon": "$(trash)"
      },
      {
        "command": "openDbNexus.refreshConnections",
        "title": "Open DB Nexus: Refresh Connections",
        "icon": "$(refresh)"
      },
      {
        "command": "openDbNexus.openTableData",
        "title": "Open DB Nexus: Open Table Data",
        "icon": "$(table)"
      },
      {
        "command": "openDbNexus.openDependencyGraph",
        "title": "Open DB Nexus: Open Dependency Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "openDbNexus.openQuery",
        "title": "Open DB Nexus: Open Query Editor",
        "icon": "$(file-code)"
      },
      {
        "command": "openDbNexus.runQuery",
        "title": "Open DB Nexus: Run Query (selected or current statement)"
      },
      {
        "command": "openDbNexus.runAllQueries",
        "title": "Open DB Nexus: Run All Queries"
      },
      {
        "command": "openDbNexus.changeQueryConnection",
        "title": "Open DB Nexus: Change Query Connection"
      },
      {
        "command": "openDbNexus.showQueryHistory",
        "title": "Open DB Nexus: Show Query History"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "openDbNexus.addConnection",
          "when": "view == openDbNexus.connections",
          "group": "navigation@1"
        },
        {
          "command": "openDbNexus.refreshConnections",
          "when": "view == openDbNexus.connections",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "openDbNexus.openQuery",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline@0"
        },
        {
          "command": "openDbNexus.testConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline@1"
        },
        {
          "command": "openDbNexus.editConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline@2"
        },
        {
          "command": "openDbNexus.deleteConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline@3"
        },
        {
          "command": "openDbNexus.editConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "1_modify@1"
        },
        {
          "command": "openDbNexus.testConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "1_modify@2"
        },
        {
          "command": "openDbNexus.deleteConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "1_modify@3"
        },
        {
          "command": "openDbNexus.openTableData",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "inline@1"
        },
        {
          "command": "openDbNexus.openDependencyGraph",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "inline@2"
        },
        {
          "command": "openDbNexus.openTableData",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "1_view@1"
        },
        {
          "command": "openDbNexus.openDependencyGraph",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "1_view@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "openDbNexus.runQuery",
        "key": "ctrl+enter",
        "when": "editorTextFocus && editorLangId == sql"
      },
      {
        "command": "openDbNexus.runAllQueries",
        "key": "ctrl+shift+enter",
        "when": "editorTextFocus && editorLangId == sql"
      }
    ],
    "configuration": {
      "title": "Open DB Nexus",
      "properties": {
        "openDbNexus.schemaCacheTtlSeconds": {
          "type": "number",
          "default": 300,
          "description": "Schema cache TTL in seconds."
        },
        "openDbNexus.query.maxRows": {
          "type": "number",
          "default": 1000,
          "description": "Maximum rows fetched by default."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./ --noEmit",
    "bundle": "node esbuild.js",
    "bundle:watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "check": "npm run compile && npm run lint && npm test && npm run package"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "^9.1.11",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "tslib": "^2.8.1"
  }
}
