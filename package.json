{
  "name": "open-db-nexus",
  "displayName": "Open DB Nexus",
  "description": "A VS Code multi-database client extension with schema explorer, query runner, and dependency graph tooling.",
  "version": "1.14.0",
  "publisher": "piupiutenshi",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/PiupiuTenshi/Database-Client.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openDbNexus",
          "title": "Open DB Nexus",
          "icon": "resources/db-nexus.svg"
        }
      ]
    },
    "views": {
      "openDbNexus": [
        {
          "id": "openDbNexus.connections",
          "name": "Connections"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "openDbNexus.connections",
        "contents": "No database connections yet.\n[Add Connection](command:openDbNexus.addConnection)"
      }
    ],
    "commands": [
      {
        "command": "openDbNexus.helloWorld",
        "title": "Open DB Nexus: Hello World"
      },
      {
        "command": "openDbNexus.addConnection",
        "title": "Open DB Nexus: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "openDbNexus.editConnection",
        "title": "Open DB Nexus: Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "openDbNexus.testConnection",
        "title": "Open DB Nexus: Test Connection",
        "icon": "$(plug)"
      },
      {
        "command": "openDbNexus.deleteConnection",
        "title": "Open DB Nexus: Delete Connection",
        "icon": "$(trash)"
      },
      {
        "command": "openDbNexus.refreshConnections",
        "title": "Open DB Nexus: Refresh Connections",
        "icon": "$(refresh)"
      },
      {
        "command": "openDbNexus.openDashboard",
        "title": "Open DB Nexus: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "openDbNexus.backupConnection",
        "title": "Open DB Nexus: Backup (logical SQL dump)",
        "icon": "$(save-all)"
      },
      {
        "command": "openDbNexus.searchSchema",
        "title": "Open DB Nexus: Search Schema (tables, views, columns)",
        "icon": "$(search)"
      },
      {
        "command": "openDbNexus.openTableData",
        "title": "Open DB Nexus: Open Table (Data & Properties)",
        "icon": "$(table)"
      },
      {
        "command": "openDbNexus.generateCode",
        "title": "Open DB Nexus: Generate Code (TypeScript / C# / CRUD)",
        "icon": "$(code)"
      },
      {
        "command": "openDbNexus.generateMockData",
        "title": "Open DB Nexus: Generate Mock Data",
        "icon": "$(beaker)"
      },
      {
        "command": "openDbNexus.openDependencyGraph",
        "title": "Open DB Nexus: Open Dependency Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "openDbNexus.openDependencyReport",
        "title": "Open DB Nexus: Open Dependency Report"
      },
      {
        "command": "openDbNexus.openQuery",
        "title": "Open DB Nexus: Open Query Editor",
        "icon": "$(file-code)"
      },
      {
        "command": "openDbNexus.runQuery",
        "title": "Open DB Nexus: Run Query (selected or current statement)"
      },
      {
        "command": "openDbNexus.runAllQueries",
        "title": "Open DB Nexus: Run All Queries"
      },
      {
        "command": "openDbNexus.changeQueryConnection",
        "title": "Open DB Nexus: Change Query Connection"
      },
      {
        "command": "openDbNexus.showQueryHistory",
        "title": "Open DB Nexus: Show Query History"
      },
      {
        "command": "openDbNexus.checkForUpdates",
        "title": "Open DB Nexus: Check for Updates",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "openDbNexus.addConnection",
          "when": "view == openDbNexus.connections",
          "group": "navigation@1"
        },
        {
          "command": "openDbNexus.refreshConnections",
          "when": "view == openDbNexus.connections",
          "group": "navigation@2"
        },
        {
          "command": "openDbNexus.checkForUpdates",
          "when": "view == openDbNexus.connections",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "openDbNexus.openQuery",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline@0"
        },
        {
          "command": "openDbNexus.testConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline@1"
        },
        {
          "command": "openDbNexus.editConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline@2"
        },
        {
          "command": "openDbNexus.deleteConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "inline@3"
        },
        {
          "command": "openDbNexus.editConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "1_modify@1"
        },
        {
          "command": "openDbNexus.testConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "1_modify@2"
        },
        {
          "command": "openDbNexus.deleteConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "1_modify@3"
        },
        {
          "command": "openDbNexus.openDashboard",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "2_manage@1"
        },
        {
          "command": "openDbNexus.backupConnection",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "2_manage@2"
        },
        {
          "command": "openDbNexus.searchSchema",
          "when": "view == openDbNexus.connections && viewItem == connection",
          "group": "2_manage@3"
        },
        {
          "command": "openDbNexus.openTableData",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "inline@1"
        },
        {
          "command": "openDbNexus.openDependencyGraph",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "inline@2"
        },
        {
          "command": "openDbNexus.openTableData",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "1_view@1"
        },
        {
          "command": "openDbNexus.openDependencyGraph",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "1_view@2"
        },
        {
          "command": "openDbNexus.openDependencyReport",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "1_view@3"
        },
        {
          "command": "openDbNexus.generateCode",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "2_generate@1"
        },
        {
          "command": "openDbNexus.generateMockData",
          "when": "view == openDbNexus.connections && viewItem == table",
          "group": "2_generate@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "openDbNexus.runQuery",
        "key": "ctrl+enter",
        "when": "editorTextFocus && editorLangId == sql"
      },
      {
        "command": "openDbNexus.runAllQueries",
        "key": "ctrl+shift+enter",
        "when": "editorTextFocus && editorLangId == sql"
      }
    ],
    "configuration": {
      "title": "Open DB Nexus",
      "properties": {
        "openDbNexus.schemaCacheTtlSeconds": {
          "type": "number",
          "default": 300,
          "description": "Schema cache TTL in seconds."
        },
        "openDbNexus.query.maxRows": {
          "type": "number",
          "default": 1000,
          "description": "Maximum rows fetched by default."
        },
        "openDbNexus.history.maxItems": {
          "type": "number",
          "default": 200,
          "description": "Maximum number of query-history entries to retain (favorites are always kept)."
        },
        "openDbNexus.metadata.loadTimeoutSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 1,
          "description": "Maximum seconds the schema tree waits for database metadata before showing a retryable timeout error."
        },
        "openDbNexus.security.disableWriteOnProduction": {
          "type": "boolean",
          "default": false,
          "description": "Hard-block all writes/DDL on connections marked as 'production'."
        },
        "openDbNexus.security.disableExportOnProduction": {
          "type": "boolean",
          "default": false,
          "description": "Hard-block data export and backup on connections marked as 'production'."
        },
        "openDbNexus.updates.autoCheckOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check GitHub Releases for Open DB Nexus updates when VS Code starts."
        },
        "openDbNexus.updates.checkIntervalHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "Minimum hours between automatic update checks."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./ --noEmit",
    "bundle": "node esbuild.js",
    "bundle:watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "package:vsix": "vsce package",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "check": "npm run compile && npm run lint && npm test && npm run package"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "^9.1.11",
    "@types/node": "^20.14.10",
    "@types/oracledb": "^7.0.1",
    "@types/pg": "^8.20.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.4-r.1",
    "better-sqlite3": "^11.10.0",
    "http-proxy-agent": "^9.1.0",
    "mongodb": "^7.3.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.22.5",
    "oracledb": "^7.0.0",
    "pg": "^8.22.0",
    "redis": "^4.7.1",
    "socks-proxy-agent": "^10.1.0",
    "tslib": "^2.8.1",
    "tunnel-ssh": "^5.2.0"
  }
}
